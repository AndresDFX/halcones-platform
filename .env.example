# Copia este archivo a .env y ajusta según tu entorno.

# Clave secreta para firmar las sesiones (cámbiala en producción).
SECRET_KEY=halcones-secret-key-2026-cambia-esto

# Token que protege el endpoint /notificaciones/cron (Render Cron Job).
CRON_SECRET=halcones-cron-secret-cambiar

# URL pública (para enlaces en los correos). En Render, tu dominio onrender.com.
PUBLIC_BASE_URL=http://localhost:8080

# Cadena de conexión a la base de datos (la usa docker-compose).
# DATABASE_URL=postgresql+psycopg://halcones:halcones@db:5432/halcones

# ---- Correo SMTP para notificaciones (opcional) ----
# Si se dejan vacías, las notificaciones se registran en modo "simulado".
# También se pueden configurar desde el panel admin (Notificaciones → Configurar correo).
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=tu_api_key
# SMTP_FROM=Halcones Paracaidismo <no-reply@tudominio.com>
